# ============================================================
# AI Inbound Lead Router - Environment Variables
#
# Copy this file to .env and fill in your own values.
# NEVER commit your real .env to version control.
# These are read by n8n at runtime (set them in your n8n
# environment, your container env, or your host .env).
# ============================================================

# ---- Webhook security ----
# Shared secret used to verify the HMAC-SHA256 signature on
# incoming webhook requests. Generate a long random value, e.g.:
#   openssl rand -hex 32
# The sender must sign the raw JSON body with this same secret
# and send the hex digest in the "X-Signature" header.
N8N_LEAD_HMAC_SECRET=replace_with_a_long_random_secret

# ---- Outbound email ----
# The "from" address used for the hot-lead auto-reply.
N8N_LEAD_FROM_EMAIL=you@yourdomain.com

# ============================================================
# The values below are NOT environment variables. They are
# configured inside n8n as Credentials and as node fields.
# Listed here only so you know everything the workflow needs.
# ============================================================

# Anthropic API key  -> stored as an n8n "Header Auth" credential
#   Header name:  x-api-key
#   Header value: <your Anthropic API key>
# ANTHROPIC_API_KEY=sk-ant-...

# Slack             -> stored as an n8n "Slack API" credential (OAuth2 or bot token)
# SLACK_CHANNEL_ID=C0000000000   (set in the Slack nodes)

# Google Sheets     -> stored as an n8n "Google Sheets / Google API" credential
# GOOGLE_SHEET_ID=YOUR_GOOGLE_SHEET_ID   (set in the Append Audit Log node)

# SMTP              -> stored as an n8n "SMTP" credential (host, port, user, pass)
