# ============================================================
# Brand Kit Studio - environment variables
#
# Copy this file to .env and fill in your own values.
# NEVER commit your real .env to version control.
# ============================================================

# ---- Provider selection ----
# Choose which LLM provider to use: "anthropic" or "openai".
LLM_PROVIDER=anthropic

# ---- API keys ----
# Set the key for whichever provider you chose above.
# You only need the one that matches LLM_PROVIDER.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ---- Model (optional) ----
# Leave blank to use the sensible default per provider:
#   anthropic -> claude-sonnet-4-6
#   openai    -> gpt-4o
# MODEL=

# ---- Limits and CORS ----
MAX_BRIEF_CHARS=1200
RATE_LIMIT_PER_MINUTE=10
# Comma-separated allowed origins for the browser. Use your real
# domain in production. "*" is fine for local development only.
ALLOWED_ORIGINS=*
